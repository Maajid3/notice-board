generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas = ["notice_app_table"]
}

enum Category {
  Exam
  Event
  General
  @@schema("notice_app_table")
}

enum Priority {
  Normal
  Urgent

  @@schema("notice_app_table")
}

model Notice {
  id          Int       @id @default(autoincrement())
  title       String
  body        String
  category    Category
  priority    Priority
  publishDate DateTime
  createdAt   DateTime  @default(now())
  @@schema("notice_app_table")
}